# Server
PORT=8081
NODE_ENV=development

# Database
DATABASE_URL="postgresql://postgres:password@127.0.0.1:5432/drp_payment"

# Server master secrets (CHANGE THESE! generate long random strings)
# INTERNAL_TOKEN  -> authenticates the payment detector (Macrodroid) callback
# ADMIN_TOKEN     -> authenticates /admin/* merchant management endpoints
INTERNAL_TOKEN=change-me-to-a-long-random-string
ADMIN_TOKEN=change-me-too

# Master key for encrypting merchant API keys (AES-256-GCM).
# Leave empty to derive from INTERNAL_TOKEN (less secure — rotasi INTERNAL_TOKEN
# akan membuat API key merchant lama tidak bisa di-decrypt).
# Recommended: set 32+ char random string here.
# ENCRYPTION_KEY=

# Public base URL gateway (no trailing slash). Dipakai untuk generate URL
# callback Macrodroid di dashboard merchant, link docs, dsb.
# Contoh production: https://pay.drpnet.my.id
# Jika tidak diset, fallback ke http://localhost:8080
# WAJIB di-set jika NODE_ENV=production (server menolak start tanpa ini).
# APP_URL=

# CORS whitelist: daftar origin (comma-separated) yang boleh akses API.
# Jika tidak diset, fallback ke APP_URL. Di development tanpa APP_URL = "*" (bebas).
# Contoh production: https://pay.drpnet.my.id,https://dashboard.drpnet.my.id
# CORS_ORIGINS=

# Admin login credentials (email + password for dashboard)
# Default: admin@drp.local / admin123 (HANYA untuk development).
# Di production (NODE_ENV=production): server MENOLAK start jika masih pakai default.
# WAJIB ganti ke email unik + password kuat sebelum deploy.
ADMIN_EMAIL=admin@drp.local
ADMIN_PASSWORD=admin123

# Default transaction TTL (minutes)
DEFAULT_EXPIRY_MINUTES=15

# QR image format (png | jpeg | webp)
QR_IMAGE_FORMAT=png

# Optional: comma-separated IPs allowed to hit /v2/callback (Phase 2)
# INTERNAL_ALLOWED_IPS=

# Optional: seed-only (used by `npm run seed`)
# SEED_MERCHANT_NAME=DRP Owner
# SEED_MERCHANT_EMAIL=you@example.com
# SEED_STATIC_QRIS=00020101021226...
# SEED_WEBHOOK_URL=https://yourapp.example.com/qris-callback
